# ─── MedChat AI Backend Configuration ─────────────────────
PORT=5000

# MongoDB Connection
# Local:   mongodb://localhost:27017/medchat
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/medchat
MONGO_URI=mongodb://localhost:27017/medchat

# JWT Secret — change this to a long random string in production!
JWT_SECRET=medchat_super_secret_jwt_key_change_me
JWT_EXPIRES_IN=7d

# CORS — frontend URL (Vite dev server)
CLIENT_URL=http://localhost:5173
